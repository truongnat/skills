{
  "name": "devkit",
  "version": "1.0.1",
  "description": "npx installer: sync devkit bundle to .agents/devkit (skills, workflows, rules, commands, KB tooling)",
  "type": "module",
  "bin": {
    "devkit": "./dist/skills.js"
  },
  "engines": {
    "node": ">=18"
  },
  "files": [
    "dist",
    "evals",
    "skills",
    "commands",
    "workflows",
    "knowledge-base",
    "prompts",
    "templates",
    "scripts",
    "AGENTS.md",
    "package.json"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx src/skills.ts",
    "lint:cli": "tsx --tsconfig tsconfig.json --no-warnings src/skills.ts --help",
    "tool": "tsx src/tools.ts",
    "list-skills": "node dist/tools.js list-skills",
    "validate-skills": "node dist/tools.js validate-skills",
    "audit-skill-structure": "node dist/tools.js audit-skill-structure",
    "eval-skill-routing": "node dist/tools.js eval-skill-routing",
    "eval-skill-output-format": "node dist/tools.js eval-skill-output-format",
    "analyze-skills": "node dist/tools.js analyze-skills",
    "build-skill-index": "node dist/tools.js build-skill-index",
    "install-skill": "node dist/tools.js install-skill",
    "verify-bundle-install": "node dist/tools.js verify-bundle-install",
    "build-kb": "node dist/tools.js build-kb",
    "index-project": "node dist/tools.js index-project",
    "generate-wiki": "node dist/tools.js generate-wiki",
    "query-kb": "node dist/tools.js query-kb",
    "query-kb-batch": "node dist/tools.js query-kb-batch",
    "verify-kb": "node dist/tools.js verify-kb",
    "build-graph": "node dist/tools.js build-graph",
    "query-graph": "node dist/tools.js query-graph",
    "impact-analysis": "node dist/tools.js impact-analysis",
    "generate-gap-analysis": "node dist/tools.js generate-gap-analysis"
  },
  "dependencies": {
    "chalk": "^5.3.0",
    "degit": "^2.8.4",
    "glob": "^11.0.0",
    "gray-matter": "^4.0.3",
    "inquirer": "^9.3.7",
    "ora": "^8.1.1",
    "yaml": "^2.5.1"
  },
  "devDependencies": {
    "@types/inquirer": "^9.0.9",
    "@types/node": "^22.13.10",
    "tsx": "^4.20.6",
    "typescript": "^5.8.2"
  },
  "keywords": [
    "cursor",
    "skills",
    "claude",
    "codex",
    "devkit",
    "installer",
    "cli"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/truongnat/skills.git"
  }
}
